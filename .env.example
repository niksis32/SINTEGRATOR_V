# Шаблон окружения. Vite НЕ читает этот файл — скопируйте нужные строки в .env или .env.local в корне проекта.
#
# Локальная заглушка «Сайт в разработке»:
#   1) Создайте .env.local с VITE_MAINTENANCE_MODE=true и VITE_MAINTENANCE_ACCESS_CODE=ваш-код
#   2) Остановите dev-сервер (Ctrl+C), снова: npm run dev
#   3) Если заглушка не видна: проверьте, что правки в .env.local; в Session Storage удалите sintegrator.maintenanceBypass
#
# Публичный URL сайта (без завершающего слэша). Должен совпадать с каноническим доменом в Search Console / Вебмастере.
# Строка Sitemap в public/robots.txt пересобирается из VITE_SITE_ORIGIN при vite dev / vite build (если сайт не закрыт роботами).
VITE_SITE_ORIGIN=https://sintegrator.ru

# Закрыть сайт от поисковых роботов: true = Disallow: / + meta noindex (см. src/config/siteVisibility.js).
# false или отсутствует = публичная индексация по правилам seoConfig.
VITE_BLOCK_SEARCH_ROBOTS=false

# Экран «Сайт в разработке» для всех гостей. Код ниже — вход в предпросмотр (хранится в sessionStorage).
VITE_MAINTENANCE_MODE=false
VITE_MAINTENANCE_ACCESS_CODE=

# -----------------------------
# Admin panel (temporary)
# -----------------------------
# Доступ к /admin. Это клиентская проверка (не серверная защита) — не используйте как единственную меру безопасности.
VITE_ADMIN_LOGIN=admin
VITE_ADMIN_PASSWORD=change-me

# Опционально: можно переопределить эндпойнт для чата (по умолчанию /api/chatbot-send.php)
VITE_CHATBOT_ENDPOINT=
