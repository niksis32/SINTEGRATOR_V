# Подтверждение регистрации по почте — выберите один вариант.

# Вариант A: свой сервер (POST JSON: { "to": "email", "confirmUrl": "https://..." })
# VITE_VERIFICATION_EMAIL_ENDPOINT=https://ваш-сайт/api/send-verification

# Вариант B: EmailJS (https://www.emailjs.com/) — в шаблоне письма: {{to_email}}, {{confirm_url}}, {{user_name}}
# VITE_EMAILJS_PUBLIC_KEY=
# VITE_EMAILJS_SERVICE_ID=
# VITE_EMAILJS_TEMPLATE_ID=
